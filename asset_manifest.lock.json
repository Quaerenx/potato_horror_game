{
  "asset_lock_version": 6,
  "purpose": "Asset lock for the Godot short horror game. Source pixels for provided character/car/creature assets must not be edited, redrawn, regenerated, cropped, stretched, recolored, mirrored, rotated, or retouched.",
  "source_policy": "Current character/ files are source of truth for provided assets; project uses byte-for-byte copies under assets/source/. The convenience store PNG is a generated project asset and is locked by hash after chroma-key removal. Provided Baekgu protector dog assets are copied byte-for-byte and locked by hash. Generated environment and flashlight lighting assets are locked by hash after project import.",
  "character_sheet_grid": {
    "columns": 8,
    "rows": 9,
    "cell_width": 192,
    "cell_height": 208,
    "use_full_cells": true,
    "do_not_trim_transparent_padding": true
  },
  "creature_motion_atlas_grid": {
    "columns": 8,
    "rows": 6,
    "cell_width": 448,
    "cell_height": 640,
    "use_full_cells": true,
    "do_not_trim_transparent_padding": true,
    "runtime_path": "assets/source/creatures/nightmare-creature-motion-atlas.png",
    "alternate_webp_path": "assets/source/creatures/nightmare-creature-motion-atlas.webp",
    "manifest_path": "assets/source/manifests/nightmare_creature_motion_manifest.json"
  },
  "generated_assets": {
    "convenience_store_prompt_summary": "Hand-drawn marker style rural Korean convenience store facade, warm lit windows, sign text ???, flat #00ff00 chroma-key background, no logos, no trademarks.",
    "chroma_key_removed": true,
    "source_path": "assets/source/buildings/convenience-store-potato-style-source.png",
    "final_path": "assets/source/buildings/convenience-store-potato-style.png"
  },
  "rules": [
    "Use supplied assets as the only hero, boyfriend, car, and creature visuals unless explicitly generated as new project assets.",
    "Do not redraw, regenerate, crop, stretch, squash, recolor, mirror, rotate, retouch, or apply AI upscaling/downscaling to supplied character/car/creature assets.",
    "Use only uniform runtime scale: Vector2(s, s), positive values only.",
    "Use full atlas cells for character and creature animations; never trim transparent padding per frame.",
    "Do not use flip_h or negative scale for character direction; left/right rows already exist.",
    "Place headlights, shadows, silhouettes, or interaction effects in separate overlay/runtime nodes; never bake effects into source images."
  ],
